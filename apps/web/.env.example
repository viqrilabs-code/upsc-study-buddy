OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
APP_ENV=development
ALLOW_LOCAL_JSON_STORE=true

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Local or non-Cloud-Run Firestore admin access
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloud Run / GCP Application Default Credentials can use the service account directly.
# GOOGLE_CLOUD_PROJECT is usually injected automatically on Cloud Run.
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
BILLING_ADMIN_EMAILS=founder@example.com,support@example.com
